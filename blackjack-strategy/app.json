{
  "expo": {
    "name": "BJ STRAT",
    "slug": "blackjack-strategy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d18"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.elishabere.blackjackstrategy",
      "buildNumber": "1",
      "deploymentTarget": "15.1",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Find nearby players on your Wi-Fi network for direct friend matches.",
        "NSBonjourServices": ["_bjarena._udp"]
      }
    },
    "android": {
      "package": "com.elishabere.blackjackstrategy",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0d18"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_MULTICAST_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "1a48807f-3967-4d16-8ed1-9ba96a8881e8"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-dev-client"
    ]
  }
}
